#PRECISA CRIAR ARQUIVO .env NO MESMO DIRETORIO DO docker-compose.yaml
# =========================
# POSTGRES
# =========================

# Banco de dados PostgreSQL
POSTGRES_DB=n8n
POSTGRES_USER=n8n_user
POSTGRES_PASSWORD=passwd_n8n

# Autenticação básica do n8n
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=admin_n8n

# DOMAIN_NAME and SUBDOMAIN together determine where n8n will be reachable from
# The top level domain to serve from
DOMAIN_NAME=seudominio.com.br

# The subdomain to serve from
SUBDOMAIN=n8n

# The above example serve n8n at: https://n8n.example.com

# Optional timezone to set which gets used by Cron and other scheduling nodes
# New York is the default value if not set
GENERIC_TIMEZONE=America/Sao_Paulo
TZ=America/Sao_Paulo

# The email address to use for the TLS/SSL certificate creation
SSL_EMAIL=seuemail@email.com
